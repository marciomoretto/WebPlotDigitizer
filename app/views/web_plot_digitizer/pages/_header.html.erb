<section class="app-header">
  <div>
    <p class="eyebrow">WebPlotDigitizer</p>
    <h1>Minimal image digitizer</h1>
    <p class="subtle">Open one image, zoom in the corner, add or delete points, and submit.</p>
  </div>

  <div class="header-actions">
    <label class="file-button">
      <span>Open image</span>
      <input type="file" accept="image/*" data-wpd-image-loader>
    </label>
  </div>
</section>
